{
    "name": "zlib",
    "version": "1.3.1.2",
    "license_files": [
        "dependencies/zlib/LICENSE"
    ],
    "build_paths" : {
        "bin_dir": "bin",
        "lib_dir": "lib",
        "include_dir": "include"
    },
    "configs": {
        "macos-arm64-Release": {
            "namespace": "deps",
            "platform": {
                "os": "macos",
                "arch": "arm64",
                "build_type": "Release"
            },
            "compiler": {
                "c": "clang",
                "cpp": "clang++"
            },
            "language": {
                "c_std": "c17",
                "cpp_std": "c++20",
                "rtti": false,
                "exceptions": false
            },
            "code_gen": {
                "build_type": "Release",
                "link_type": "Static"
            },
            "runtime": {
                "stdlib": "libc++",
                "deployment_target": "12.0"
            }
        },
        "macos-arm64-Debug": {
            "namespace": "deps",
            "platform": {
                "os": "macos",
                "arch": "arm64",
                "build_type": "Debug"
            },
            "compiler": {
                "c": "clang",
                "cpp": "clang++"
            },
            "language": {
                "c_std": "c17",
                "cpp_std": "c++20",
                "rtti": false,
                "exceptions": false
            },
            "code_gen": {
                "build_type": "Debug",
                "link_type": "Static"
            },
            "runtime": {
                "stdlib": "libc++",
                "deployment_target": "12.0"
            }
        },
        "windows-x86_64-Release": {
            "namespace": "deps",
            "platform": {
                "os": "windows",
                "arch": "x86_64",
                "build_type": "Release"
            },
            "compiler": {
                "c": "cl",
                "cpp": "cl"
            },
            "language": {
                "c_std": "c17",
                "cpp_std": "c++20",
                "rtti": false,
                "exceptions": false
            },
            "code_gen": {
                "build_type": "Release",
                "link_type": "Static"
            },
            "runtime": {
                "stdlib": "msvc",
                "deployment_target": ""
            }
        },
        "windows-x86_64-Debug": {
            "namespace": "deps",
            "platform": {
                "os": "windows",
                "arch": "x86_64",
                "build_type": "Debug"
            },
            "compiler": {
                "c": "cl",
                "cpp": "cl"
            },
            "language": {
                "c_std": "c17",
                "cpp_std": "c++20",
                "rtti": false,
                "exceptions": false
            },
            "code_gen": {
                "build_type": "Debug",
                "link_type": "Static"
            },
            "runtime": {
                "stdlib": "msvc",
                "deployment_target": ""
            }
        }
    },
    "options": {
        "BUILD_SHARED_LIBS": false
    }
}