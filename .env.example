# Copy this file to `.env` and fill in real values.
# `.env` is gitignored; only `./run.sh deploy <preset>` reads these.
# `build` and `bundle` do not require any of them.

# AWS credentials used to upload bundles to S3.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 region the bucket lives in (e.g. us-east-1).
AWS_REGION=

# Target bucket and key prefix. The uploaded object path is:
#   <AWS_S3_UPLOAD_ROOT>/<name>/<triple>/<buildType>/<bundle>.zip
AWS_S3_BUCKET=
AWS_S3_UPLOAD_ROOT=
